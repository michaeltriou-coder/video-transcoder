# All settings are optional. In the portable build the launcher sets sensible
# defaults and resolves bundled binaries automatically — you normally need none.
PORT=5000
# STORAGE_PATH defaults to <portable-root>/data
# STORAGE_PATH=./data
WHISPER_BACKEND=cpp
WHISPER_MODEL=base
# Absolute paths only needed for non-portable/dev setups:
# WHISPER_CPP_PATH=
# YTDLP_PATH=
# FFMPEG_PATH=
# FFPROBE_PATH=
MAX_CONCURRENT_JOBS=1
BASE_URL=http://localhost:5000
CORS_ORIGIN=*
